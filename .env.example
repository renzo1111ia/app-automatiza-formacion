# 🌐 CONFIGURACIÓN DEL SERVIDOR
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 🗄️ INFRAESTRUCTURA DE SUPABASE (BASE DE DATOS Y RLS)
# Reemplazar con las URLs correspondientes del proyecto en desarrollo/producción
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 🎙️ PROVEEDOR DE VOZ IA (RETELL AI)
RETELL_API_KEY=key_...
RETELL_AGENT_ID=agent_...

# 💬 MENSAJERÍA META BUSINESS (WHATSAPP BUSINESS API)
WHATSAPP_ACCESS_TOKEN=EAAB...
WHATSAPP_PHONE_NUMBER_ID=...
WHATSAPP_BUSINESS_ACCOUNT_ID=...

# 🧠 PROVEEDORES DE INTELIGENCIA ARTIFICIAL (COGNICIÓN Y EXTRACTOR DE DATOS)
OPENAI_API_KEY=sk-proj-...

# ⏱️ COLA DE TAREAS Y REDIS (BULLMQ)
# Requerido para el procesamiento asíncrono de llamadas y reintentos
REDIS_URL=redis://localhost:6379
